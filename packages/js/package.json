{
  "name": "@ppokyd/pb-validator",
  "version": "0.1.0",
  "description": "Validate Prebid bidder params using JSON Schemas aligned with prebid.github.io and prebid-server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/index.d.ts",
        "require": "./dist/cjs/index-node.js",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js",
        "default": "./dist/browser.js"
      },
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "generate": "node scripts/generate-types.mjs",
    "build": "npm run generate && tsc && tsc --project tsconfig.cjs.json && node scripts/write-cjs-pkg.mjs && node scripts/copy-schemas.mjs",
    "test": "npm run build && node --test dist/index.test.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "prebid",
    "adapter",
    "validation",
    "json-schema"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "ajv": "^8.12.0"
  }
}
