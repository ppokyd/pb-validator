{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/smartico.json",
  "title": "smartico bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (smartico.md).",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "string",
      "description": "Unique identificator per widget integration provided by customer"
    },
    "token": {
      "type": "string",
      "description": "Unique 40-symbols identificator per customer provided by smartico"
    },
    "region": {
      "type": "string",
      "description": "Creative region alias"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Creative region aliases list"
    },
    "bannerFormat": {
      "type": "string",
      "description": "Specific banner format alias"
    },
    "language": {
      "type": "string",
      "description": "Two letter language code"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "required": [
        "placementId"
      ]
    },
    {
      "required": [
        "token"
      ]
    }
  ]
}
