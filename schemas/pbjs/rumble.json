{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/rumble.json",
  "title": "Rumble Advertising Center bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (rumble.md).",
  "type": "object",
  "properties": {
    "publisherId": {
      "type": "number",
      "description": "Account publishing ID"
    },
    "siteId": {
      "type": "number",
      "description": "The site ID you want to send requests"
    },
    "zoneId": {
      "type": "number",
      "description": "An optional zone ID that you want to force requests to"
    },
    "test": {
      "type": "boolean",
      "description": "An optional boolean flag for sending test requests"
    }
  },
  "additionalProperties": false,
  "required": [
    "publisherId",
    "siteId"
  ]
}
