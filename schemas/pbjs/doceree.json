{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/doceree.json",
  "title": "Doceree bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (doceree.md).",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "string",
      "description": "Placement Id"
    },
    "publisherUrl": {
      "type": "string",
      "description": "Current url"
    },
    "gdpr": {
      "type": "string",
      "description": "Flag to check if gdpr applies"
    },
    "gdprConsent": {
      "type": "string",
      "description": "URL-safe base64-encoded Transparency & Consent string"
    }
  },
  "additionalProperties": false,
  "required": [
    "placementId"
  ]
}
