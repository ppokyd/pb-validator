{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/alkimi.json",
  "title": "Alkimi bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (alkimi.md).",
  "x-source-url": "https://github.com/prebid/prebid.github.io/blob/e2559b3ae8367f0a851736c18ee18965806e803a/dev-docs/bidders/alkimi.md",
  "type": "object",
  "properties": {
    "token": {
      "type": "string",
      "description": "The ID issued by Alkimi to the publisher"
    },
    "bidFloor": {
      "type": "number",
      "description": "Minimum bid for this impression expressed in CPM."
    },
    "instl": {
      "type": "integer",
      "description": "Set to 1 if using interstitial (default: 0)"
    },
    "exp": {
      "type": "integer",
      "description": "Advisory as to the number of seconds that may elapse between the auction and the actual impression."
    }
  },
  "additionalProperties": false,
  "required": [
    "token"
  ]
}
