{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/flipp.json",
  "title": "flipp bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (flipp.md).",
  "type": "object",
  "properties": {
    "publisherNameIdentifier": {
      "type": "string",
      "description": "Publisher name identifier"
    },
    "creativeType": {
      "description": "Type of the creative"
    },
    "siteId": {
      "type": "integer",
      "description": "ID associated with the site"
    },
    "zoneIds": {
      "description": "Zones to request from bidder"
    },
    "userKey": {
      "description": "User Key to power experience optimization and frequency capping. Publishers: please confirm with legal counsel before using this feature."
    },
    "options": {
      "description": "Additional integration specific context"
    },
    "Name": {
      "description": "Description"
    },
    "startCompact": {
      "type": "boolean",
      "description": "Height of the experience will be reduced"
    },
    "dwellExpand": {
      "type": "boolean",
      "description": "Auto expand the experience after a certain time passes"
    },
    "contentCode": {
      "type": "string",
      "description": "Force show a certain experience. Generally used for testing and debugging purposes."
    }
  },
  "additionalProperties": false,
  "required": [
    "publisherNameIdentifier",
    "creativeType",
    "siteId"
  ]
}
