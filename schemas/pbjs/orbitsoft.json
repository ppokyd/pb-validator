{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/orbitsoft.json",
  "title": "Orbitsoft bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (orbitsoft.md).",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "integer",
      "description": "The placement ID (site channel ID)"
    },
    "requestUrl": {
      "type": "string",
      "description": "Url to perform search request"
    },
    "style": {
      "type": "string",
      "description": "Creative styles. Actual only for text ads"
    },
    "customParams": {
      "type": "object",
      "description": "Permits passing any publisher key-value pairing into the bid request"
    }
  },
  "additionalProperties": false,
  "required": [
    "placementId",
    "requestUrl"
  ]
}
