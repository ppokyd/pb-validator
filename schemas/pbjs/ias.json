{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/ias.json",
  "title": "Integral Ad Science (IAS) bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (ias.md).",
  "type": "object",
  "properties": {
    "pubId": {
      "type": "string",
      "description": "Publisher client ID, provided by IAS"
    },
    "adUnitPath": {
      "type": "string",
      "description": "Ad unit path. The same one you use for GPT"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "required": [
        "pubId"
      ]
    },
    {
      "required": [
        "adUnitPath"
      ]
    }
  ]
}
