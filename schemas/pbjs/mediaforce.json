{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbjs/mediaforce.json",
  "title": "MediaForce bidder params (Prebid.js)",
  "description": "Generated from prebid.github.io dev-docs/bidders (mediaforce.md).",
  "type": "object",
  "properties": {
    "bidfloor": {
      "type": "number",
      "description": "The floor price, or minimum amount, a publisher will accept for an impression, given in CPM in USD."
    },
    "placement_id": {
      "type": "string",
      "description": "Identifier for specific ad placement"
    },
    "publisher_id": {
      "type": "string",
      "description": "The publisher ID assigned to the publisher by MediaForce"
    }
  },
  "additionalProperties": false,
  "required": [
    "placement_id",
    "publisher_id"
  ]
}
