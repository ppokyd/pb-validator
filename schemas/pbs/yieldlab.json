{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/yieldlab.json",
  "title": "Yieldlab bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Yieldlab adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/yieldlab.json",
  "type": "object",
  "properties": {
    "adslotId": {
      "type": "string",
      "description": "Yieldlab ID of the ad slot"
    },
    "supplyId": {
      "type": "string",
      "description": "Yieldlab ID of the supply"
    },
    "extId": {
      "type": "string",
      "description": "External ID used for reporting"
    },
    "targeting": {
      "type": "object",
      "description": "Targeting information in key value pairs"
    }
  },
  "required": [
    "adslotId",
    "supplyId"
  ]
}
