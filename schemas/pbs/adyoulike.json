{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/adyoulike.json",
  "title": "AdYouLike bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the AdYouLike adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/adyoulike.json",
  "type": "object",
  "properties": {
    "placement": {
      "type": "string",
      "description": "Placement Id"
    },
    "campaign": {
      "type": "string",
      "description": "Id of a forced campaign"
    },
    "track": {
      "type": "string",
      "description": "Id of a forced Track"
    },
    "creative": {
      "type": "string",
      "description": "Id of a forced creative"
    },
    "source": {
      "type": "string",
      "description": "context of the campaign"
    },
    "debug": {
      "type": "string",
      "description": "Arbitrary id used for debug purpose"
    }
  },
  "required": [
    "placement"
  ]
}
