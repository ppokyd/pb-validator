{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/trafficgate.json",
  "title": "TrafficGate bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the TrafficGate adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/trafficgate.json",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "string",
      "minLength": 1,
      "description": "An ID which identifies the TrafficGate placement"
    },
    "host": {
      "type": "string",
      "minLength": 1,
      "description": "An ID which identifies the TrafficGate host"
    },
    "customParams": {
      "type": "object",
      "description": "User-defined targeting key-value pairs."
    }
  },
  "required": [
    "placementId",
    "host"
  ]
}
