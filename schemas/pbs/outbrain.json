{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/outbrain.json",
  "title": "Outbrain bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Outbrain adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/outbrain.json",
  "type": "object",
  "properties": {
    "publisher": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    },
    "tagid": {
      "type": "string"
    },
    "bcat": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "badv": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "publisher"
  ]
}
