{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/unicorn.json",
  "title": "UNICORN bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the UNICORN adapter",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "string",
      "description": "In Application, if placementId is empty, prebid server configuration id will be used as placementId."
    },
    "publisherId": {
      "type": "string",
      "description": "Account specific publisher id"
    },
    "mediaId": {
      "type": "string",
      "description": "Publisher specific media id"
    },
    "accountId": {
      "type": "integer",
      "description": "Account ID for charge request"
    }
  },
  "required": [
    "accountId"
  ],
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/unicorn.json"
}
