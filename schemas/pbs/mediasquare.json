{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/mediasquare.json",
  "title": "Mediasquare bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Mediasquare adapter",
  "type": "object",
  "properties": {
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "The owner provided for mediasquare."
    },
    "code": {
      "type": "string",
      "minLength": 1,
      "description": "The code provided for mediasquare."
    }
  },
  "required": [
    "owner",
    "code"
  ]
}
