  "$id": "https://prebid.org/schemas/pbs/silvermob.json",
  "title": "SilverMob bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the SilverMob adapter",
  "type": "object",
  "properties": {
    "zoneid": {
      "type": "string",
      "description": "Zone ID"
    },
    "host": {
      "type": "string",
      "description": "Host"
    }
