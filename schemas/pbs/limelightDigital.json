{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/limelightDigital.json",
  "title": "Limelight Digital bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Limelight Digital adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/limelightDigital.json",
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "description": "Ad network's RTB host",
      "format": "hostname",
      "pattern": "^.+\\..+$"
    },
    "publisherId": {
      "type": [
        "integer",
        "string"
      ],
      "description": "Publisher ID",
      "minimum": 1,
      "pattern": "^[1-9][0-9]*$"
    }
  },
  "required": [
    "host",
    "publisherId"
  ]
}
