{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/taboola.json",
  "title": "Taboola bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Taboola adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/taboola.json",
  "type": "object",
  "properties": {
    "publisherId": {
      "type": "string"
    },
    "publisherDomain": {
      "type": "string"
    },
    "tagid": {
      "type": "string",
      "description": "Deprecated, use tagId instead."
    },
    "tagId": {
      "type": "string",
      "description": "preferred, will get precedence if both tagId and tagid are defined"
    },
    "bidfloor": {
      "type": "number"
    },
    "bcat": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "badv": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pageType": {
      "type": "string"
    },
    "position": {
      "type": "integer"
    }
  },
  "oneOf": [
    {
      "required": [
        "tagid",
        "publisherId"
      ]
    },
    {
      "required": [
        "tagId",
        "publisherId"
      ]
    }
  ]
}
