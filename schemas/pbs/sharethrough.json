{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/sharethrough.json",
  "title": "Sharethrough bidder params (Prebid Server)",
  "description": "A schema which validates params accepted by the Sharethrough adapter",
  "x-source-url": "https://github.com/prebid/prebid-server/blob/99009c08fb6204ec10f236653a7fc47c229339c3/static/bidder-params/sharethrough.json",
  "type": "object",
  "properties": {
    "pkey": {
      "type": "string",
      "description": "Placement Key"
    },
    "badv": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string"
      },
      "description": "Blocked Advertiser Domains"
    },
    "bcat": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string"
      },
      "description": "Blocked IAB Categories"
    }
  },
  "required": [
    "pkey"
  ]
}
