{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://prebid.org/schemas/pbs/cpmstar.json",
  "title": "Cpmstar bidder params (Prebid Server)",
  "description": "Schema to validate params accepted by the Cpmstar adapter",
  "type": "object",
  "properties": {
    "placementId": {
      "type": "integer",
      "description": "Cpmstar-specific ID for ad pool"
    },
    "subpoolId": {
      "type": "integer",
      "description": "Cpmstar-specific ID for ad subpool"
    }
  },
  "required": [
    "placementId"
  ]
}
